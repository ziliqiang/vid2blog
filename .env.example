# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===========================================
# AI 模型配置（三选一）
# 数据更新日期：2026年7月6日
# ===========================================

# --- 方案 A：DeepSeek V4（推荐，最便宜） ---
# 注册：platform.deepseek.com（新账户送500万token）
# OpenAI SDK 完全兼容，改两行代码即可
# 旧模型名 deepseek-chat 将于 2026-07-24 废弃，请用新名称
OPENAI_API_KEY=your_deepseek_api_key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash

# --- 方案 B：OpenAI 官方 ---
# 注册：platform.openai.com（需海外信用卡）
# GPT-4o 仍然可用（未停用）
# OPENAI_API_KEY=sk-your_openai_key
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini

# --- 方案 C：中转站（OpenAI 兼容接口） ---
# 填你的中转站地址和 Key
# 服务器必须在海外，Vercel 才能调用
# OPENAI_API_KEY=your_relay_key
# OPENAI_BASE_URL=https://your-relay.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ===========================================
# 2026年7月模型价格参考（每百万token，USD）
# 数据来源：aipricing.guru / DeepSeek 官方文档
# 更新日期：2026-07-06
# ===========================================
#
# DeepSeek V4 Flash:  输入 $0.14  输出 $0.28  （缓存命中 $0.028）  1M上下文
# DeepSeek V4 Pro:    输入 $1.74  输出 $3.48  （缓存命中 $0.145）  1M上下文
# GPT-4.1 nano:       输入 $0.10  输出 $0.40                        1M上下文  ← OpenAI最便宜
# GPT-4o mini:        输入 $0.15  输出 $0.60                        128K上下文
# GPT-4.1 mini:       输入 $0.40  输出 $1.60                        1M上下文
# GPT-5.4 nano:       输入 $0.20  输出 $1.25
# GPT-5.4 mini:       输入 $0.75  输出 $4.50
# GPT-4o:             输入 $2.50  输出 $10.00  （仍然可用）
# GPT-5.4:            输入 $2.50  输出 $15.00
# GPT-5 (5.2):        输入 $1.75  输出 $14.00
# GPT-5.5:            输入 $5.00  输出 $30.00  （2026年4月发布）
# GPT-5.6 Luna:       输入 $1.00  输出 $6.00   （2026年6月发布，限量预览）
# GPT-5.6 Terra:      输入 $2.50  输出 $15.00  （限量预览）
# GPT-5.6 Sol:        输入 $5.00  输出 $30.00  （限量预览）
#
# 注意：GPT-5.6 系列（Sol/Terra/Luna）目前仅向"可信合作伙伴"开放，普通API无法调用
# 注意：DeepSeek 旧模型名 deepseek-chat / deepseek-reasoner 将于 2026-07-24 废弃

# Creem Payment
CREEM_SECRET_KEY=your_creem_secret_key
CREEM_PRO_PRODUCT_ID=your_creem_pro_product_id
CREEM_BUSINESS_PRODUCT_ID=your_creem_business_product_id

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
